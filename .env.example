# Live mode is optional. Demo Mode works without a key.
NODE_ENV=development
HOST=127.0.0.1
PORT=3000
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-sol
OPENAI_REASONING_EFFORT=medium
# Selected potentially long-running core methods (including TEST, VALIDATE,
# STRESS_TEST, and ROOT_CAUSE) use recoverable background execution. Short
# methods retain the ordinary 8,000-token synchronous path.
OPENAI_LONG_REASONING_MAX_OUTPUT_TOKENS=12000
REASONING_MAX_AGE_MS=540000
REASONING_POLL_AFTER_MS=2000
# Public research needs room for web-search reasoning, balanced findings, citations,
# structured Evidence Items, coverage metadata, and confidence/update rationale.
# Ordinary router/cycle calls retain the smaller code default; these settings apply
# only to evidence-acquisition calls. A safe retry after output exhaustion may use
# the retry ceiling.
OPENAI_RESEARCH_MAX_OUTPUT_TOKENS=32000
OPENAI_RESEARCH_RETRY_MAX_OUTPUT_TOKENS=64000
# Keep this within OpenAI's temporary background-response retrieval window when store=false.
RESEARCH_MAX_AGE_MS=540000
RESEARCH_POLL_AFTER_MS=2000
